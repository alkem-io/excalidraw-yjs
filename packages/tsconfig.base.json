{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@excalidraw-yjs/common": ["./common/src/index.ts"],
      "@excalidraw-yjs/common/*": ["./common/src/*"],
      "@excalidraw-yjs/element": ["./element/src/index.ts"],
      "@excalidraw-yjs/element/*": ["./element/src/*"],
      "@excalidraw-yjs/excalidraw": ["./excalidraw/index.tsx"],
      "@excalidraw-yjs/excalidraw/*": ["./excalidraw/*"],
      "@excalidraw-yjs/math": ["./math/src/index.ts"],
      "@excalidraw-yjs/math/*": ["./math/src/*"],
      "@excalidraw-yjs/utils": ["./utils/src/index.ts"],
      "@excalidraw-yjs/utils/*": ["./utils/src/*"],
      "@excalidraw-yjs/fractional-indexing": ["./fractional-indexing/src/index.ts"],
      "@excalidraw-yjs/fractional-indexing/*": ["./fractional-indexing/src/*"],
      "@excalidraw-yjs/excalidraw": ["./excalidraw/index.tsx"],
      "@excalidraw-yjs/excalidraw/element/*": ["./element/src/*"],
      "@excalidraw-yjs/excalidraw/*": ["./excalidraw/*"]
    }
  }
}
